# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://trial:trial@localhost:5433/billing_trial?schema=public"

# API server
API_PORT=4000

# Web server
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Gateway webhook secrets (mock — do not use real values)
AUTHORIZE_NET_WEBHOOK_SECRET="trial-authorize-net-webhook-secret-do-not-use-in-prod"
SOLANA_WEBHOOK_SECRET="trial-solana-webhook-secret-do-not-use-in-prod"

# Crypto confirmation depth required before crediting ledger
SOLANA_REQUIRED_CONFIRMATIONS=3

# Feature flags
SIMULATOR_ENABLED=true
NODE_ENV=development
